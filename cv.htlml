<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Professional CV - Haleema Muhyyudin</title>
<style>
/* Body and CV container */
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #f5f6fa;
    margin: 0;
    padding: 20px;
    color: #333;
}
.cv {
    max-width: 850px;
    margin: auto;
    background: #fff;
    padding: 35px;
    border-radius: 10px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.05);
}

/* Header */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
}
.header-left h1 {
    margin: 0;
    font-size: 32px;
    color: #4a4aff;
}
.header-left p {
    margin: 2px 0;
    font-size: 14px;
    color: #555;
}

/* Profile circle */
.circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background-color: #4a4aff;
    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
    font-weight: bold;
    font-size: 32px;
    border: 3px solid #4a4aff;
}

/* Section Titles */
.section-title {
    color: #4a4aff;
    font-weight: bold;
    font-size: 16px;
    margin-top: 25px;
    margin-bottom: 10px;
    text-transform: uppercase;
}

/* Paragraphs and lists */
p, li {
    font-size: 14px;
    line-height: 1.6;
    color: #444;
    margin: 4px 0;
}
ul {
    padding-left: 20px;
}

/* Footer */
.footer {
    text-align: center;
    margin-top: 30px;
    font-size: 13px;
    color: #777;
}
</style>
</head>
<body>

<div class="cv">

    <!-- Header -->
    <div class="header">
        <div class="header-left">
            <h1>Haleema Muhyyudin</h1>
            <p>BS Information Technology - 3rd Year</p>
            <p>University of Education, Lahore (Multan Campus)</p>
            <p><strong>Session:</strong> 2023 - 2027</p>
            <p><strong>Roll Number:</strong> bsf23004148</p>
            <p><strong>Email:</strong> your@gmail.com</p>
            <p><strong>Phone:</strong> +92XXXXXXXXXX</p>
            <p><strong>Location:</strong> Multan, Pakistan</p>
        </div>
        <div class="circle">HM</div>
    </div>

    <!-- About Me -->
    <div class="section-title">About Me</div>
    <p>
        I am a student learning IT. I like computers, web design, and technology. 
        I am eager to learn new skills and improve myself.
    </p>

    <!-- Education -->
    <div class="section-title">Education</div>
    <ul>
        <li><strong>BS Information Technology</strong><br>
            University of Education, Lahore (2023–2027)
        </li>
        <li><strong>ICS</strong><br>
            Nishat College of Science for Girls, Multan (2021–2023)
        </li>
        <li><strong>Matriculation (Science)</strong><br>
            New Haven Public High School, Multan (2019–2021)
        </li>
    </ul>

    <!-- Skills -->
    <div class="section-title">Skills</div>
    <ul>
        <li>HTML</li>
        <li>CSS</li>
        <li>Microsoft Word</li>
        <li>UI/UX (Basic)</li>
    </ul>

    <!-- Experience -->
    <div class="section-title">Experience</div>
    <p>No work experience yet</p>

    <!-- Languages -->
    <div class="section-title">Languages</div>
    <ul>
        <li>Urdu - Native</li>
        <li>English - Intermediate</li>
    </ul>

    <!-- Footer -->
    <div class="footer">
        References available upon request
    </div>

</div>

</body>
</html>